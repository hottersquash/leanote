{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Revel (manual)",
      "type": "go",
      "request": "attach",
      "mode": "local",
      "processId": 0,
      "showLog": true
    },
    {
      "name": "Launch Leanote (revel run)",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${env:USERPROFILE}\\go\\bin\\revel.exe",
      "args": ["run", "-a", "."],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/scripts/dev.env"
    }
  ]
}
